<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <PackageId>Contriwork.Notifications</PackageId>
    <Description>TODO: one-line description of the package. Mirrors CONTRACT.md.</Description>
    <PackageTags>contriwork</PackageTags>
    <GeneratePackageOnBuild>false</GeneratePackageOnBuild>
    <IsPackable>true</IsPackable>
    <RootNamespace>Contriwork.Notifications</RootNamespace>
    <AssemblyName>Contriwork.Notifications</AssemblyName>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <PackageReadmeFile>README.md</PackageReadmeFile>
